# ─────────────────────────────────────────────────────────────────────────────
# Rajasthan Special Needs Infrastructure Survey System
# Environment Variables
#
# Copy this file to .env.local for local development and fill in your values.
# Set the same variables in Vercel → Project Settings → Environment Variables
# for production and preview deployments.
#
# NEVER commit .env.local or any file containing real secrets to git.
# .env*.local is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
#
# Found in your Supabase project dashboard → Settings → API
#
# NEXT_PUBLIC_ prefix means these are safe to expose to the browser.
# They only allow operations permitted by your Row Level Security (RLS) policies.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The service role key bypasses RLS — used ONLY in server-side code (Server
# Actions, Route Handlers).  NEVER prefix with NEXT_PUBLIC_.
# Keep this secret. Rotate it immediately if ever exposed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
